# Copia este fichero a `.env` y ajusta lo que necesites (todo es opcional).

# Ruta al modelo entrenado.
# MODEL_PATH=./model/EfficientNetB0_best.keras

# Modo de preprocesado. "rescale" = imagen/255 (coincide con el entrenamiento).
# Otros: "efficientnet" (no-op en Keras moderno), "raw".
# PREPROCESS=rescale

# Tamano de entrada del modelo.
# IMG_SIZE=224

# Umbral de decision (>umbral => rotten).
# THRESHOLD=0.5

# Tamano maximo de imagen en bytes (10 MB por defecto).
# MAX_IMAGE_BYTES=10485760

# Origenes CORS permitidos (separados por comas).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
